{
  "name": "micracode",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI-powered web app builder with in-browser Node.js preview.",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "engines": {
    "node": "22.18.0",
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun run --parallel dev:web dev:api",
    "dev:web": "bun --filter web dev",
    "dev:api": "uv run --directory apps/api uvicorn micracode_api.main:app --reload --host 127.0.0.1 --port 8000",
    "build": "bun --filter web build",
    "start:web": "bun --filter web start",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "bun --filter '*' lint",
    "format": "bun --filter '*' format",
    "test:api": "uv run --directory apps/api pytest",
    "api:install": "uv sync --directory apps/api",
    "api:lint": "uv run --directory apps/api ruff check .",
    "api:format": "uv run --directory apps/api ruff format ."
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.193",
    "ai": "^6.0.191"
  }
}